<Window
    x:Class="StudyWPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:StudyWPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    mc:Ignorable="d">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="44"
            GlassFrameThickness="0"
            ResizeBorderThickness="5"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="TransparentBrush" Color="Transparent" />
        <!--  关闭按钮样式  -->
        <!--#region 关闭按钮样式-->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource TransparentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TransparentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#FF458077" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding Content}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--#endregion-->


        <!--#region 菜单样式-->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource TransparentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TransparentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#FF458077" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <!--#endregion-->
    </Window.Resources>
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/DesktopBackground/03.jpg" />
            <!--<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#e3f7fe" Offset="0" />
            <GradientStop Color="#cceeff" Offset="1" />
            </LinearGradientBrush>-->
        </Grid.Background>

        <Border
            Background="Transparent"
            BorderBrush="Black"
            BorderThickness="1"
            CornerRadius="10">

            <Grid x:Name="MainGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="10,10,20,0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#FF458077">
                            我的程序
                        </TextBlock>
                        <Menu Padding="0,10,10,0">
                            <MenuItem Header="时间表" />
                            <MenuItem Header="课程表" Click="MenuItem_Click" />
                            <MenuItem Header="当天课程" />
                        </Menu>
                    </StackPanel>
                    <StackPanel
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        MouseDown="StackPanel_MouseDown"
                        Orientation="Horizontal"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button
                            Width="30"
                            Height="30"
                            Margin="5"
                            Click="BtnMin_Click"
                            Content="—" />
                        <Button
                            x:Name="MaximizeButton"
                            Width="30"
                            Height="30"
                            Margin="5"
                            Click="MaximizeButton_Click"
                            Content="🔲" />
                        <Button
                            Width="30"
                            Height="30"
                            Margin="5"
                            Click="Button_Click"
                            Content="X" />

                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1">
                    <Frame  x:Name="MainFrame" Source="Pages/Index.xaml" NavigationUIVisibility="Hidden" ></Frame>

                </Grid>
            </Grid>

        </Border>
    </Grid>
</Window>
