<Page
    x:Class="StudyWPF.AddCurricula"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:StudyWPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="clr-namespace:StudyWPF.ViewModels"
    Title="AddCurricula"

    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Page.DataContext>
        <vm:AddCurriculaVM/>
    </Page.DataContext>
    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5,0,5,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <!--  内容居左  -->
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Width" Value="400" />
        </Style>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition x:Name="Shuru" Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <!--  星期几  -->
            <RowDefinition Height="50" />
            <!--  第几节  -->
            <RowDefinition Height="50" />
            <!--  哪个班  -->
            <RowDefinition Height="50" />
            <!--  任务类型  -->
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            Margin="10"
            FontSize="18"
            Text="星期" />
        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            Margin="10"
            FontSize="18"
            Text="节次" />
        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            Margin="10"
            FontSize="18"
            Text="班级" />
        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            Margin="10"
            FontSize="18"
            Text="任务类型" />

        <TextBox
            Grid.Row="1"
            Grid.Column="1"
            Margin="10" />
        <TextBox
            Grid.Row="2"
            Grid.Column="1"
            Margin="10" />
        <TextBox
            Grid.Row="3"
            Grid.Column="1"
            Margin="10" />
        <Grid Grid.Row="4" Grid.ColumnSpan="2">
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <Button
                    Width="120"
                    Margin="10"
                    Content="添加" />
                <Button
                    Width="120"
                    Margin="10"
                    Content="清空" />
            </StackPanel>
        </Grid>
        <!--  直接绑定枚举 DayOfWeek  -->

        <ComboBox
            Name="CboWeek"
            Grid.Row="0"
            Grid.Column="1"
            HorizontalAlignment="Left"
            Width="120"
            Margin="10"
            ItemsSource="{Binding WeekList}"
            VerticalAlignment="Center" SelectedIndex="0"
            DisplayMemberPath="Text"  SelectedValuePath="Value" />
        <!---->

        <!--  选中的值是枚举  -->

    </Grid>
</Page>
